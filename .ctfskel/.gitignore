# Room-local state — never commit.
.venv/
.direnv/
engagement_files/
.browser/
mnt/

# Local VS Code state, except the shared extension recommendations.
.vscode/*
!.vscode/extensions.json

# Per-host overrides (alt CTF_VPN_DIR, lab DNS, …).
.envrc.local

# VPN configs carry private keys / certs — keep them in $CTF_VPN_DIR
# (default ~/ctf/vpn), out of the room and out of git.
*.ovpn
*.conf
vpn/
