# shellcheck shell=bash
# CTF engagement room — layer 1: tooling devShell + python venv.
# Layer 2 (the VPN network namespace) is entered on demand with `room-enter`.

set -u

# Prefer system iproute2 over any busybox applet on PATH (the netns-detection
# probe and route inspection below depend on real `ip`).
PATH="/run/current-system/sw/bin:$PATH"

ROOM_ROOT="$(pwd)"
ROOM_NAME="$(basename "$ROOM_ROOT")"
export ROOM_ROOT ROOM_NAME

# Auto-load the flake's devShell — every binary the room needs (the tunnel
# stack + the network tools) comes from here. nix-direnv caches it, so
# subsequent `cd`s are instant; only a flake.nix change triggers a rebuild.
use flake

# Sanitize PYTHONPATH. mkShell's setup hooks export the full python3.13 closure
# of the nix CLI tools (impacket, smbmap, samba, certipy, …) into PYTHONPATH.
# CPython honors PYTHONPATH regardless of version, so the room's 3.12 venv
# interpreter (jupyter/paramiko) would load the nix 3.13 cryptography and crash
# on `undefined symbol: Py_GetConstantBorrowed`. The nix tools are wrapped and
# set their own PYTHONPATH internally, so clearing the shell-level one is safe.
unset PYTHONPATH NIX_PYTHONPATH

# ---------------------------------------------------------------------------
# Shared VPN config directory. Drop HTB/THM/etc. configs here as <name>.ovpn
# (or <name>.conf for WireGuard); enter with `room-enter <name>`. Override the
# location per-host in .envrc.local.
# ---------------------------------------------------------------------------
: "${CTF_VPN_DIR:=$HOME/ctf/vpn}"
export CTF_VPN_DIR

# Per-room runtime dir (tmpfs, vanishes at logout). Holder pid / ready flag /
# unbound + hosts files live here, keyed by room name so two rooms' namespaces
# never collide.
CTF_RUNTIME="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ctf-$ROOM_NAME"
mkdir -p "$CTF_RUNTIME"; chmod 700 "$CTF_RUNTIME"
export CTF_RUNTIME

# Optional split-DNS targets for an internal lab domain (forwarded into the
# netns by room-enter). Leave unset for plain HTB/THM (the addhost command
# covers per-box hostnames); set these for engagements with their own resolver.
#   CTF_LAB_DOMAIN  e.g. lab.local
#   CTF_LAB_DNS     e.g. 10.10.10.2
export CTF_LAB_DOMAIN="${CTF_LAB_DOMAIN:-}"
export CTF_LAB_DNS="${CTF_LAB_DNS:-}"

# ---------------------------------------------------------------------------
# Python venv for the notebook deps (jupyterlab, pwntools, chepy, selenium,
# paramiko, sshtunnel, bs4, …). These are pip-only / fast-moving, so they live
# in a .venv rather than the flake. Bootstrap idempotently: rebuild only when
# requirements.txt changes (stamp keyed on its sha). Uses uv for speed.
# ---------------------------------------------------------------------------
if [[ -f "$ROOM_ROOT/requirements.txt" ]] && has uv; then
  _req_stamp="$ROOM_ROOT/.venv/.requirements.sha"
  _req_now="$(sha256sum "$ROOM_ROOT/requirements.txt" | cut -d' ' -f1)"
  if [[ ! -d "$ROOM_ROOT/.venv" ]]; then
    echo "[ctf room] creating python venv (.venv)…" >&2
    uv venv "$ROOM_ROOT/.venv" >&2
  fi
  if [[ ! -f "$_req_stamp" || "$(cat "$_req_stamp" 2>/dev/null)" != "$_req_now" ]]; then
    echo "[ctf room] installing requirements.txt into .venv…" >&2
    if VIRTUAL_ENV="$ROOM_ROOT/.venv" uv pip install -r "$ROOM_ROOT/requirements.txt" >&2; then
      echo "$_req_now" > "$_req_stamp"
    else
      echo "[ctf room] warning: requirements install failed — fix and re-enter" >&2
    fi
  fi
  # Put the venv on PATH so `python`, `jupyter`, `ipython` resolve to it.
  PATH_add "$ROOM_ROOT/.venv/bin"
  export VIRTUAL_ENV="$ROOM_ROOT/.venv"
  unset _req_stamp _req_now
fi

# Room helper scripts: room-enter, addhost, _room-enter-inner.
PATH_add "$ROOM_ROOT/bin"

export CTF_ROOM=1

# Per-host overrides (gitignored): alternate CTF_VPN_DIR, lab DNS, etc.
if [[ -f "$ROOM_ROOT/.envrc.local" ]]; then
  # shellcheck source=/dev/null
  source "$ROOM_ROOT/.envrc.local"
fi

# ---------------------------------------------------------------------------
# Banner. room-enter's inner shell exports CTF_LAYER=2; outside it we're on
# the host network (layer 1) and print how to get into the tunnel.
# ---------------------------------------------------------------------------
if [[ "${CTF_LAYER:-1}" != 2 ]]; then
  cat <<EOF

╭─ ctf room: $ROOM_NAME ─ layer 1 (host network) ───────────────────────────╮
  Egress is your real ISP — no VPN yet. Tools + venv are ready.

  Enter the engagement VPN
    room-enter <name>     bring up (or join) the VPN netns  [e.g. room-enter htb]
    room-enter list       list configs in \$CTF_VPN_DIR
    room-enter status     show namespace + tunnel state
    room-enter down       tear the namespace down

  Once inside, set your targets
    addhost box.htb 10.129.10.5     map a hostname for shell + notebook + tools

  VPN configs: $CTF_VPN_DIR
╰───────────────────────────────────────────────────────────────────────────╯
EOF
fi
